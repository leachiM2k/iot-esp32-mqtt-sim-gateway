# Copy to .env and fill in. .env is git-ignored.

# Broker (matches the firmware's MQTT_SERVER, but as a TCP URL)
MQTT_URL=mqtt://dev.rotmanov.de:1883

# MQTT user for the bridge. Needs to receive events AND publish commands,
# i.e. publish rights on esp32/commands/<MAC>.
MQTT_USERNAME=esp32a7670web
MQTT_PASSWORD=changeme

# Local web server port
PORT=8787

# Topic bases (only change if you changed them in the firmware's constants.h)
EVENTS_BASE=esp32/events
COMMANDS_BASE=esp32/commands
