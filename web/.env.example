# Copy to .env and fill in. .env is git-ignored.

# Broker (matches the firmware's MQTT_SERVER, but as a TCP URL)
MQTT_URL=mqtt://dev.rotmanov.de:1883

# Read-only user: receives status/SMS/call events
MQTT_USERNAME=esp32a7670readonly
MQTT_PASSWORD=changeme

# OPTIONAL: a user WITH publish rights on esp32/commands/<MAC>.
# Needed to send commands (call/accept/hangup/sms/reboot). If left unset,
# commands are published through the read-only user above and will not reach
# the board on a broker that denies it publish access.
# MQTT_CMD_USERNAME=esp32a7670
# MQTT_CMD_PASSWORD=changeme

# Local web server port
PORT=8787

# Topic bases (only change if you changed them in the firmware's constants.h)
EVENTS_BASE=esp32/events
COMMANDS_BASE=esp32/commands
